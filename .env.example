# =========================================================================
# .env.example — Salin ke .env untuk run lokal, ATAU set sebagai GitHub Secrets.
# JANGAN commit .env asli (sudah di .gitignore).
# =========================================================================

# --- WAJIB ---
# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token
# Chat/channel ID tujuan notifikasi (lihat README cara ambil)
TELEGRAM_CHAT_ID=123456789
# Helius API key (free tier) dari https://dev.helius.xyz
HELIUS_API_KEY=your-helius-free-api-key

# --- OPSIONAL (Stage 7 narasi) ---
# YouTube Data API v3 key (gratis 10k unit/hari). Kosongkan utk skip YouTube.
YOUTUBE_API_KEY=
# Matikan seluruh modul narasi bila ingin run lebih cepat/ringan:
NARRATIVE_ENABLED=true

# --- Relay Meteora (penting untuk GitHub Actions) ---
# Cloudflare Meteora memblokir IP data-center (runner GitHub -> 404). Bot otomatis
# fallback lewat relay publik ini kalau request langsung gagal. Kosongkan bila kamu
# run dari IP residential (tak diblokir) atau punya relay sendiri.
# Format: {url} diganti URL Meteora lengkap yang sudah di-URL-encode.
# METEORA_PROXY=https://api.allorigins.win/raw?url={url}

# --- OPSIONAL: tuning threshold (default sudah di config.py) ---
# MIN_TVL_USD=10000
# MIN_BASE_FEE_PCT=2
# MIN_BIN_STEP=100
# MIN_CUMULATIVE_FEE_SOL=20
# MIN_MARKET_CAP_USD=300000
# MIN_VOLUME_H24_USD=1000000
# ATH_PROXIMITY_PCT=5
# MAX_TOP10_SUPPLY_PCT=30
# MAX_TRANSFER_FEE_BPS=50

# --- OPSIONAL: bobot scoring (total default = 100) ---
# W_FEE_TVL=25
# W_VOL_TVL=15
# W_VOLATILITY=20
# W_HOLDER=15
# W_LP_CONC=10
# W_NARRATIVE=10
# W_POOL_AGE=5
# VERDICT_STRONG_MIN=65
# VERDICT_WATCH_MIN=40

# --- OPSIONAL: operasional ---
# DRY_RUN=false            # true = proses tapi tak kirim Telegram (testing)
# SEND_SKIP_AUDIT=false    # true = kirim SKIP ringkas untuk audit
# MAX_POOLS_PER_RUN=60
# MAX_EXPENSIVE_CANDIDATES=15
# RENOTIFY_COOLDOWN_HOURS=24
