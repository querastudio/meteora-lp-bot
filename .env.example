# =========================================================================
# .env.example — Salin ke .env untuk run lokal, ATAU set sebagai GitHub Secrets.
# JANGAN commit .env asli (sudah di .gitignore).
# =========================================================================

# --- WAJIB ---
# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=123456:ABC-your-telegram-bot-token
# Chat/channel ID tujuan notifikasi (lihat README cara ambil)
TELEGRAM_CHAT_ID=123456789
# Helius API key (free tier) dari https://dev.helius.xyz
HELIUS_API_KEY=your-helius-free-api-key

# --- OPSIONAL (Stage 7 narasi: Viralitas + Daya Tahan) ---
# YouTube Data API v3 key (gratis 10k unit/hari). Kosongkan utk skip YouTube.
YOUTUBE_API_KEY=
# Matikan seluruh modul narasi bila ingin run lebih cepat/ringan:
NARRATIVE_ENABLED=true
# Reddit (gratis, no key). Matikan bila endpoint mulai kena rate-limit/berubah:
REDDIT_ENABLED=true
# Gemini API key gratis (Google AI Studio, https://aistudio.google.com/apikey)
# -- dipakai HANYA utk klasifikasi organik/terkoordinasi narasi (soft nudge,
# bukan hard gate). Kosongkan utk skip (narasi tetap jalan tanpa AI check).
GEMINI_API_KEY=
GEMINI_NARRATIVE_ENABLED=true
# Groq API key gratis (https://console.groq.com/keys) -- FALLBACK kalau
# Gemini gagal/kena limit harian (rate limit gratis Groq lebih longgar).
# Kosongkan utk skip (tetap fallback ke narasi rule-based biasa).
GROQ_API_KEY=
GROQ_NARRATIVE_ENABLED=true

# --- OPSIONAL (momentum VWAP via GeckoTerminal, gratis no key) ---
VWAP_MOMENTUM_ENABLED=true

# --- OPSIONAL, BERBAYAR (~$24/bln): sinyal sosial X via LunarCrush ---
# https://lunarcrush.com/pricing/ -- TIDAK meng-index token super baru
# (dikonfirmasi manual), jadi nyaris selalu n/a utk kandidat fresh -- itu
# wajar. Kosongkan utk skip sepenuhnya (gratis, tak ada dampak ke pipeline).
LUNARCRUSH_API_KEY=
LUNARCRUSH_ENABLED=true

# --- OPSIONAL (Jupiter Organic Score, gratis no key) -- deteksi wash-trading ---
JUPITER_ORGANIC_ENABLED=true

# --- OPSIONAL (GMGN OpenAPI, gratis) -- security cross-check, dev holding %,
# tag holder (smart_degen/bundler/sniper/rat_trader). Apply key gratis di
# https://gmgn.ai/ai (submit public key Ed25519, tak ada prompt bayar).
# INFORMASIONAL SAJA (tampil di notif), tak menyentuh skor/hard gate.
GMGN_API_KEY=
GMGN_ENABLED=true

# --- OPSIONAL: tuning threshold (default sudah di config.py) ---
# MIN_TVL_USD=10000
# MIN_BASE_FEE_PCT=2
# MIN_BIN_STEP=100
# MIN_CUMULATIVE_FEE_SOL=20
# MIN_MARKET_CAP_USD=300000
# MIN_VOLUME_H24_USD=1000000
# MAX_TOP10_SUPPLY_PCT=30
# MAX_TRANSFER_FEE_BPS=50
# AI_MIN_REDDIT_POSTS=2      # di bawah ini + news tipis -> skip AI check narasi
# AI_MIN_NEWS_ARTICLES=3

# --- OPSIONAL: bobot scoring (total default = 100) ---
# W_FEE_TVL=25
# W_VOL_TVL=15
# W_VOLATILITY=20
# W_HOLDER=15
# W_LP_CONC=10
# W_NARRATIVE=10
# W_VWAP_MOMENTUM=8
# W_LUNARCRUSH=8
# W_JUPITER_ORGANIC=10
# W_POOL_AGE=5
# VERDICT_STRONG_MIN=65
# VERDICT_WATCH_MIN=40

# --- OPSIONAL: operasional ---
# DRY_RUN=false            # true = proses tapi tak kirim Telegram (testing)
# SEND_SKIP_AUDIT=false    # true = kirim SKIP ringkas untuk audit
# MAX_POOLS_PER_RUN=300
# MAX_EXPENSIVE_CANDIDATES=15
# RENOTIFY_COOLDOWN_HOURS=24
